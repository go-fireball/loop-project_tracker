diff --git a/apps/project-tracker/templates/tracker/project_detail.html b/apps/project-tracker/templates/tracker/project_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..7cd8d820a832c1ef72a0c82958dbfc0386f90cca
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/project_detail.html
@@ -0,0 +1,61 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}{{ project.name }}{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>{{ project.name }}</h2>
+        <p class="section-copy">{{ project.description|default:"No description provided yet." }}</p>
+      </div>
+      <a class="inline-link" href="{% url 'tracker:project_list' %}">All projects</a>
+    </div>
+    <div class="meta-cluster">
+      <span class="badge">{{ project.get_status_display }}</span>
+      <span class="meta-copy">Created {{ project.created_date }}</span>
+      {% for tag in project.tags.all %}
+        <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+      {% empty %}
+        <span class="meta-copy">No tags</span>
+      {% endfor %}
+    </div>
+  </section>
+
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Tasks</h2>
+        <p class="section-copy">Tasks assigned to this project, including due dates and shared tags.</p>
+      </div>
+    </div>
+    {% if project.tasks.all %}
+      <div class="stack">
+        {% for task in project.tasks.all %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3>{{ task.title }}</h3>
+              <p>{{ task.get_status_display }} priority: {{ task.get_priority_display }}</p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ task.get_status_display }}</span>
+              <span class="meta-copy">Priority {{ task.get_priority_display }}</span>
+              {% if task.due_date %}
+                <span class="meta-copy">Due {{ task.due_date }}</span>
+              {% else %}
+                <span class="meta-copy">No due date</span>
+              {% endif %}
+              {% for tag in task.tags.all %}
+                <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+              {% empty %}
+                <span class="meta-copy">No tags</span>
+              {% endfor %}
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">This project does not have tasks yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/apps/project-tracker/templates/tracker/project_list.html b/apps/project-tracker/templates/tracker/project_list.html
