@@ -0,0 +1,40 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}Projects{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Projects</h2>
+        <p class="section-copy">Every tracked project with its current status, tags, and task totals.</p>
+      </div>
+      <a class="inline-link" href="{% url 'tracker:dashboard' %}">Back to dashboard</a>
+    </div>
+    {% if projects %}
+      <div class="stack">
+        {% for project in projects %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3><a href="{% url 'tracker:project_detail' project.id %}">{{ project.name }}</a></h3>
+              <p>{{ project.description|default:"No description provided yet." }}</p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ project.get_status_display }}</span>
+              <span class="meta-copy">{{ project.task_count }} total tasks</span>
+              <span class="meta-copy">{{ project.open_task_count }} open tasks</span>
+              <span class="meta-copy">Created {{ project.created_date }}</span>
+              {% for tag in project.tags.all %}
+                <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+              {% empty %}
+                <span class="meta-copy">No tags</span>
+              {% endfor %}
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">No projects have been created yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
