diff --git a/apps/project-tracker/templates/tracker/project_detail.html b/apps/project-tracker/templates/tracker/project_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..7cd8d820a832c1ef72a0c82958dbfc0386f90cca
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/project_detail.html
@@ -0,0 +1,61 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}{{ project.name }}{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>{{ project.name }}</h2>
+        <p class="section-copy">{{ project.description|default:"No description provided yet." }}</p>
+      </div>
+      <a class="inline-link" href="{% url 'tracker:project_list' %}">All projects</a>
+    </div>
+    <div class="meta-cluster">
+      <span class="badge">{{ project.get_status_display }}</span>
+      <span class="meta-copy">Created {{ project.created_date }}</span>
+      {% for tag in project.tags.all %}
+        <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+      {% empty %}
+        <span class="meta-copy">No tags</span>
+      {% endfor %}
+    </div>
+  </section>
+
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Tasks</h2>
+        <p class="section-copy">Tasks assigned to this project, including due dates and shared tags.</p>
+      </div>
+    </div>
+    {% if project.tasks.all %}
+      <div class="stack">
+        {% for task in project.tasks.all %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3>{{ task.title }}</h3>
+              <p>{{ task.get_status_display }} priority: {{ task.get_priority_display }}</p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ task.get_status_display }}</span>
+              <span class="meta-copy">Priority {{ task.get_priority_display }}</span>
+              {% if task.due_date %}
+                <span class="meta-copy">Due {{ task.due_date }}</span>
+              {% else %}
+                <span class="meta-copy">No due date</span>
+              {% endif %}
+              {% for tag in task.tags.all %}
+                <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+              {% empty %}
+                <span class="meta-copy">No tags</span>
+              {% endfor %}
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">This project does not have tasks yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/apps/project-tracker/templates/tracker/project_list.html b/apps/project-tracker/templates/tracker/project_list.html
new file mode 100644
index 0000000000000000000000000000000000000000..0b38ad5aa7533d8dc24f47363568ec491ebc265e
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/project_list.html
@@ -0,0 +1,40 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}Projects{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Projects</h2>
+        <p class="section-copy">Every tracked project with its current status, tags, and task totals.</p>
+      </div>
+      <a class="inline-link" href="{% url 'tracker:dashboard' %}">Back to dashboard</a>
+    </div>
+    {% if projects %}
+      <div class="stack">
+        {% for project in projects %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3><a href="{% url 'tracker:project_detail' project.id %}">{{ project.name }}</a></h3>
+              <p>{{ project.description|default:"No description provided yet." }}</p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ project.get_status_display }}</span>
+              <span class="meta-copy">{{ project.task_count }} total tasks</span>
+              <span class="meta-copy">{{ project.open_task_count }} open tasks</span>
+              <span class="meta-copy">Created {{ project.created_date }}</span>
+              {% for tag in project.tags.all %}
+                <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+              {% empty %}
+                <span class="meta-copy">No tags</span>
+              {% endfor %}
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">No projects have been created yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
diff --git a/apps/project-tracker/templates/tracker/tag_detail.html b/apps/project-tracker/templates/tracker/tag_detail.html
new file mode 100644
index 0000000000000000000000000000000000000000..4581ec906efd694947b13a342ef5108e4beedd98
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/tag_detail.html
@@ -0,0 +1,72 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}{{ tag.name }}{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Tag: {{ tag.name }}</h2>
+        <p class="section-copy">Projects and tasks associated with this shared tracker tag.</p>
+      </div>
+      <a class="inline-link" href="{% url 'tracker:project_list' %}">Browse projects</a>
+    </div>
+  </section>
+
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Projects</h2>
+      </div>
+    </div>
+    {% if tag.projects.all %}
+      <div class="stack">
+        {% for project in tag.projects.all %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3><a href="{% url 'tracker:project_detail' project.id %}">{{ project.name }}</a></h3>
+              <p>{{ project.description|default:"No description provided yet." }}</p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ project.get_status_display }}</span>
+              <span class="meta-copy">Created {{ project.created_date }}</span>
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">No projects use this tag yet.</p>
+    {% endif %}
+  </section>
+
+  <section class="panel">
+    <div class="panel-heading">
+      <div>
+        <h2>Tasks</h2>
+      </div>
+    </div>
+    {% if tag.tasks.all %}
+      <div class="stack">
+        {% for task in tag.tasks.all %}
+          <article class="list-card">
+            <div class="list-card-main">
+              <h3>{{ task.title }}</h3>
+              <p><a href="{% url 'tracker:project_detail' task.project.id %}">{{ task.project.name }}</a></p>
+            </div>
+            <div class="meta-cluster">
+              <span class="badge">{{ task.get_status_display }}</span>
+              <span class="meta-copy">Priority {{ task.get_priority_display }}</span>
+              {% if task.due_date %}
+                <span class="meta-copy">Due {{ task.due_date }}</span>
+              {% else %}
+                <span class="meta-copy">No due date</span>
+              {% endif %}
+            </div>
+          </article>
+        {% endfor %}
+      </div>
+    {% else %}
+      <p class="empty-state">No tasks use this tag yet.</p>
+    {% endif %}
+  </section>
+{% endblock %}
