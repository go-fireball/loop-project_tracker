+                        "project_detail",
+                        request.path,
+                        f"Edit {project.name}",
+                        "Save changes",
+                    ),
+                )
+            ],
+        )
+
+    if request.method != "POST":
+        return HttpResponseNotAllowed(["GET", "POST"])
+
+    form = ProjectForm(request.POST, instance=project)
+    if form.is_valid():
+        project = form.save()
