diff --git a/apps/project-tracker/tracker/tests/test_views.py b/apps/project-tracker/tracker/tests/test_views.py
index 641dc5816e4ce1ddabfc2495212ddd33c30cd497..254d96c7db5b48fff721a36567c8625598b4d21b
