diff --git a/apps/project-tracker/templates/tracker/partials/project_form_panel.html b/apps/project-tracker/templates/tracker/partials/project_form_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..f2959329f73e193deff50d8a6cdfcb54b432a0da
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/project_form_panel.html
@@ -0,0 +1,64 @@
+<section class="panel form-panel">
+  <div class="panel-heading">
+    <div>
+      <h2>{{ form_heading }}</h2>
+      <p class="section-copy">Project changes save through the current page without a full reload.</p>
+    </div>
+  </div>
+  <form
+    class="project-form"
+    action="{{ form_action }}"
+    method="post"
+    data-async-form
+  >
+    {% csrf_token %}
+    <input type="hidden" name="source_page" value="{{ source_page }}">
+    {% if form.non_field_errors %}
+      <div class="form-errors" role="alert">
+        {% for error in form.non_field_errors %}
+          <p>{{ error }}</p>
+        {% endfor %}
+      </div>
+    {% endif %}
+    <div class="form-grid">
+      <div class="field-group field-span-2">
+        <label for="{{ form.name.id_for_label }}">Name</label>
+        {{ form.name }}
+        {% for error in form.name.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group field-span-2">
+        <label for="{{ form.description.id_for_label }}">Description</label>
+        {{ form.description }}
+        {% for error in form.description.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group">
+        <label for="{{ form.status.id_for_label }}">Status</label>
+        {{ form.status }}
+        {% for error in form.status.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group">
+        <label for="{{ form.created_date.id_for_label }}">Created date</label>
+        {{ form.created_date }}
+        {% for error in form.created_date.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group field-span-2">
+        <label for="{{ form.tags.id_for_label }}">Tags</label>
+        {{ form.tags }}
+        {% for error in form.tags.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+    </div>
+    <div class="form-actions">
+      <button class="button-primary" type="submit">{{ form_submit_label }}</button>
+    </div>
+  </form>
+</section>
diff --git a/apps/project-tracker/templates/tracker/partials/project_list_panel.html b/apps/project-tracker/templates/tracker/partials/project_list_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..5e824ed8a3ff2aad4acfd24c54e4b60750618a81
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/project_list_panel.html
@@ -0,0 +1,18 @@
+<section class="panel">
+  <div class="panel-heading">
+    <div>
+      <h2>Projects</h2>
+      <p class="section-copy">Every tracked project with its current status, tags, and task totals.</p>
+    </div>
+    <a class="inline-link" href="{% url 'tracker:dashboard' %}">Back to dashboard</a>
+  </div>
+  {% if projects %}
+    <div class="stack">
+      {% for project in projects %}
+        {% include "tracker/partials/project_card.html" with source_page="project_list" %}
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty-state">No projects have been created yet.</p>
+  {% endif %}
+</section>
