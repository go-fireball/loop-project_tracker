diff --git a/apps/project-tracker/templates/tracker/partials/project_detail_panel.html b/apps/project-tracker/templates/tracker/partials/project_detail_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..3404819b07004d04cb7f16a48906ccdaed8e949e
--- /dev/null
