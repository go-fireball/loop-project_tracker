+                    ),
+                    (
+                        "#dashboard-recent-projects-region",
+                        "tracker/partials/dashboard_recent_projects_panel.html",
+                        dashboard_context,
+                    ),
+                ],
+            )
+
+        blank_form = ProjectForm()
