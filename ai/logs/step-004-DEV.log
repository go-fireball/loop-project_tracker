diff --git a/apps/project-tracker/templates/tracker/partials/tag_form_panel.html b/apps/project-tracker/templates/tracker/partials/tag_form_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..8c213bf78f77c9697e69b61f477410765fff9b15
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/tag_form_panel.html
@@ -0,0 +1,38 @@
+<section class="panel form-panel">
+  <div class="panel-heading">
+    <div>
+      <h2>{{ form_heading }}</h2>
+      <p class="section-copy">Tag changes save through this page without a full reload.</p>
+    </div>
+  </div>
+  <form
+    class="project-form"
+    action="{{ form_action }}"
+    method="post"
+    data-async-form
+  >
+    {% csrf_token %}
+    {% if form.non_field_errors %}
+      <div class="form-errors" role="alert">
+        {% for error in form.non_field_errors %}
+          <p>{{ error }}</p>
+        {% endfor %}
+      </div>
+    {% endif %}
+    <div class="form-grid">
+      <div class="field-group field-span-2">
+        <label for="{{ form.name.id_for_label }}">Name</label>
+        {{ form.name }}
+        {% for error in form.name.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+    </div>
+    <div class="form-actions">
+      <button class="button-primary" type="submit">{{ form_submit_label }}</button>
+      {% if cancel_url %}
+        <a class="button-secondary" href="{{ cancel_url }}" data-async-link>Cancel</a>
+      {% endif %}
+    </div>
+  </form>
+</section>
diff --git a/apps/project-tracker/templates/tracker/partials/tag_list_panel.html b/apps/project-tracker/templates/tracker/partials/tag_list_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..74680f887740e3c1dfd0a865126c9428af0a694d
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/tag_list_panel.html
@@ -0,0 +1,28 @@
+<section class="panel">
+  <div class="panel-heading">
+    <div>
+      <h2>All tags</h2>
+      <p class="section-copy">Select a tag to inspect its related projects and tasks.</p>
+    </div>
+  </div>
+  {% if tags %}
+    <div class="stack">
+      {% for tag in tags %}
+        <article class="list-card {% if selected_tag_id == tag.id %}list-card-active{% endif %}">
+          <div class="list-card-main">
+            <h3>
+              <a class="inline-link" href="{% url 'tracker:tag_detail' tag.id %}" data-async-link>{{ tag.name }}</a>
+            </h3>
+            <p>{{ tag.project_count }} projects and {{ tag.task_count }} tasks use this tag.</p>
+          </div>
+          <div class="meta-cluster">
+            <span class="badge">{{ tag.project_count }} projects</span>
+            <span class="badge">{{ tag.task_count }} tasks</span>
+          </div>
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty-state">No tags exist yet.</p>
+  {% endif %}
+</section>
