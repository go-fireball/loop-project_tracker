@@ -0,0 +1,23 @@
+{% load static %}
+<!DOCTYPE html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>{% block title %}{{ page_title|default:"Project Tracker" }}{% endblock %}</title>
+    <link rel="stylesheet" href="{% static 'tracker/app.css' %}">
+  </head>
+  <body>
+    <div class="app-shell">
+      <header class="app-header">
+        <p class="eyebrow">Django scaffold</p>
+        <h1>Project Tracker</h1>
+        <p class="lede">Single-project baseline wired for templates, static assets, and future CRUD views.</p>
+      </header>
+      <main>
+        {% block content %}{% endblock %}
+      </main>
+    </div>
+    <script src="{% static 'tracker/app.js' %}" defer></script>
+  </body>
+</html>
diff --git a/apps/project-tracker/templates/tracker/dashboard.html b/apps/project-tracker/templates/tracker/dashboard.html
new file mode 100644
index 0000000000000000000000000000000000000000..376f7b57081bdb816cbe8c34f8c40bc14cb3badd
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/dashboard.html
@@ -0,0 +1,18 @@
+{% extends "tracker/base.html" %}
+
+{% block title %}Project Tracker{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <h2>Baseline route is live</h2>
+    <p>The Django project scaffold is connected end to end.</p>
+    <ul class="checklist">
+      <li>Root URLconf includes the tracker app.</li>
+      <li>Templates resolve from the shared project template directory.</li>
+      <li>Static CSS and JavaScript are loaded through Django static files.</li>
+    </ul>
+    {% if app_ready %}
+      <p class="status">Ready for models, forms, and asynchronous CRUD slices.</p>
+    {% endif %}
+  </section>
+{% endblock %}
