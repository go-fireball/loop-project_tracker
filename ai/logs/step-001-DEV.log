+  --border: #d7c6b2;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  min-height: 100vh;
+  font-family: Georgia, "Times New Roman", serif;
+  background:
+    radial-gradient(circle at top left, rgba(28, 107, 90, 0.12), transparent 32%),
+    linear-gradient(180deg, #f7f2ea 0%, var(--bg) 100%);
+  color: var(--ink);
+}
+
+.app-shell {
+  width: min(100% - 2rem, 64rem);
+  margin: 0 auto;
+  padding: 3rem 0 4rem;
+}
+
+.app-header {
+  margin-bottom: 2rem;
+}
+
