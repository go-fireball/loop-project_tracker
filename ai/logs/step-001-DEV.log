+{% extends "tracker/base.html" %}
+
+{% block title %}Project Tracker{% endblock %}
+
+{% block content %}
+  <section class="panel">
+    <h2>Baseline route is live</h2>
+    <p>The Django project scaffold is connected end to end.</p>
+    <ul class="checklist">
+      <li>Root URLconf includes the tracker app.</li>
+      <li>Templates resolve from the shared project template directory.</li>
+      <li>Static CSS and JavaScript are loaded through Django static files.</li>
+    </ul>
+    {% if app_ready %}
+      <p class="status">Ready for models, forms, and asynchronous CRUD slices.</p>
+    {% endif %}
+  </section>
+{% endblock %}
