diff --git a/apps/project-tracker/templates/tracker/partials/task_form_panel.html b/apps/project-tracker/templates/tracker/partials/task_form_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..b3b2057bd35065c46de7306bbd92b46c1c32e846
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/task_form_panel.html
@@ -0,0 +1,63 @@
+<section class="panel form-panel">
+  <div class="panel-heading">
+    <div>
+      <h2>{{ form_heading }}</h2>
+      <p class="section-copy">Task changes save through this project page without a full reload.</p>
+    </div>
+  </div>
+  <form
+    class="project-form"
+    action="{{ form_action }}"
+    method="post"
+    data-async-form
+  >
+    {% csrf_token %}
+    {% if form.non_field_errors %}
+      <div class="form-errors" role="alert">
+        {% for error in form.non_field_errors %}
+          <p>{{ error }}</p>
+        {% endfor %}
+      </div>
+    {% endif %}
+    <div class="form-grid">
+      <div class="field-group field-span-2">
+        <label for="{{ form.title.id_for_label }}">Title</label>
+        {{ form.title }}
+        {% for error in form.title.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group">
+        <label for="{{ form.status.id_for_label }}">Status</label>
+        {{ form.status }}
+        {% for error in form.status.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group">
+        <label for="{{ form.priority.id_for_label }}">Priority</label>
+        {{ form.priority }}
+        {% for error in form.priority.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group field-span-2">
+        <label for="{{ form.due_date.id_for_label }}">Due date</label>
+        {{ form.due_date }}
+        {% for error in form.due_date.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+      <div class="field-group field-span-2">
+        <label for="{{ form.tags.id_for_label }}">Tags</label>
+        {{ form.tags }}
+        {% for error in form.tags.errors %}
+          <p class="field-error">{{ error }}</p>
+        {% endfor %}
+      </div>
+    </div>
+    <div class="form-actions">
+      <button class="button-primary" type="submit">{{ form_submit_label }}</button>
+    </div>
+  </form>
+</section>
diff --git a/apps/project-tracker/templates/tracker/partials/task_list_panel.html b/apps/project-tracker/templates/tracker/partials/task_list_panel.html
new file mode 100644
index 0000000000000000000000000000000000000000..8651c07f8925b7fcae494c83d9739f14e7397a72
--- /dev/null
+++ b/apps/project-tracker/templates/tracker/partials/task_list_panel.html
@@ -0,0 +1,50 @@
+<section class="panel">
+  <div class="panel-heading">
+    <div>
+      <h2>Tasks</h2>
+      <p class="section-copy">Tasks assigned to this project, including due dates and shared tags.</p>
+    </div>
+  </div>
+  {% if project.tasks.all %}
+    <div class="stack">
+      {% for task in project.tasks.all %}
+        <article class="list-card">
+          <div class="list-card-main">
+            <h3>{{ task.title }}</h3>
+            <p>{{ task.get_status_display }} priority: {{ task.get_priority_display }}</p>
+          </div>
+          <div class="meta-cluster">
+            <span class="badge">{{ task.get_status_display }}</span>
+            <span class="meta-copy">Priority {{ task.get_priority_display }}</span>
+            {% if task.due_date %}
+              <span class="meta-copy">Due {{ task.due_date }}</span>
+            {% else %}
+              <span class="meta-copy">No due date</span>
+            {% endif %}
+            {% for tag in task.tags.all %}
+              <a class="chip" href="{% url 'tracker:tag_detail' tag.id %}">{{ tag.name }}</a>
+            {% empty %}
+              <span class="meta-copy">No tags</span>
+            {% endfor %}
+            <a
+              class="button-secondary"
+              href="{% url 'tracker:task_update' project.id task.id %}"
+              data-async-link
+            >Edit task</a>
+            <form
+              action="{% url 'tracker:task_delete' project.id task.id %}"
+              method="post"
+              data-async-form
+              data-confirm="Delete {{ task.title }}?"
+            >
+              {% csrf_token %}
+              <button class="button-secondary" type="submit">Delete task</button>
+            </form>
+          </div>
+        </article>
+      {% endfor %}
+    </div>
+  {% else %}
+    <p class="empty-state">This project does not have tasks yet.</p>
+  {% endif %}
+</section>
